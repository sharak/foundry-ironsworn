{{#*inline "progress"}}
    <button type="button" class="mark-progress" data-id="{{vow._id}}" data-marks="{{ vow.data.level }}">{{ localize 'IRONSWORN.Mark' }}</button>
    {{#rangeProgress from=from to=to marks=vow.data.current}}
        <div class="sheet-progress-input {{cls}}">
            <span class="mark">|</span>
            <span class="mark">|</span>
            <span class="mark">|</span>
            <span class="mark">|</span>
        </div>
    {{/rangeProgress}}
    <button type="button" class="fulfill-progress" data-id="{{vow._id}}" data-marks="{{ vow.data.level }}">{{ localize 'IRONSWORN.Fulfill' }}</button>
{{/inline}}
<div class="flexrow">

    <div class="flexcol">
        <section class="sheet-area">
            <h1>{{ localize 'IRONSWORN.Vows' }}</h1>
            {{#each vows as |vow id|}}
                <h3 class="sheet-progress-title">
                    <a class="progress-fulfill">{{ vow.name }} ({{ localizeDifficulty vow.data.level }})</a>
                </h3>
                <div class="flexrow sheet-progress">
                    {{>progress vow=vow from=1 to=10}}
                </div>
            {{/each}}
            <button type="button" class="add-item" data-type="vow">{{ localize 'IRONSWORN.AddVow' }}</button>
        </section>
    </div>
</div>
